# Database (NeonDB in production, local Postgres in development)
# Pooled URL for the runtime — use Neon's "-pooler" hostname in prod
DATABASE_URL=postgresql://user:password@host:5432/db?pgbouncer=true&connection_limit=1
# Direct (unpooled) URL for migrations only — required by Prisma
DIRECT_URL=postgresql://user:password@host:5432/db

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-base64
BETTER_AUTH_URL=http://localhost:3000

# Superadmins — comma-separated emails granted admin-panel access at runtime.
# Authority is config, not DB state: an account is privileged iff its email is listed here.
# These emails self-register their password at /admin/registro.
SUPERADMIN_EMAILS=you@example.com,teammate@example.com

# Cloudflare R2 (image hosting; served publicly via cdn.homara.es)
# Account ID is the hex prefix of the R2 S3 endpoint.
R2_ACCOUNT_ID=
# Generated in Cloudflare → R2 → Manage API Tokens (scope: Object Read & Write, single bucket).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=products
R2_PUBLIC_BASE_URL=https://cdn.homara.es

# Resend (transactional email; currently dormant — only logged in dev)
RESEND_API_KEY=

# Amazon Creators API (product scraping + price sync)
# Credentials are issued in Associates Central → Creators API (needs an Associate
# account with ≥10 qualifying sales in the last 30 days). Version selects the auth
# flow: 3.x = Login with Amazon, 2.x = Cognito. EU marketplaces use v3.2 / v2.2.
AMAZON_CREATOR_API_CREDENTIAL_ID=
AMAZON_CREATOR_API_CREDENTIAL_SECRET=
AMAZON_CREATOR_API_VERSION=v3.2
# Associates tracking id appended to every vended link (must match the marketplace).
AMAZON_PARTNER_TAG=ahorrhogar-21
AMAZON_MARKETPLACE=www.amazon.es
# Optional: account TPS allocation (defaults to 1). Raise once Amazon scales you up.
AMAZON_TPS=1

# Cron — bearer token guarding /api/cron/amazon-sync. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. Generate with: openssl rand -base64 32
CRON_SECRET=

# Public site URL used by sitemap.ts and robots.ts. Defaults to https://homara.es when unset.
NEXT_PUBLIC_SITE_URL=https://homara.es

# Google Analytics 4
# Server-only var read in layout.tsx and passed via prop. Unset locally = no GA loaded.
GA_ID=
# Required to fire server-side Measurement Protocol events (affiliate redirect, AI crawler visits).
GA4_API_SECRET=
