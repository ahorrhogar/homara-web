# Database (NeonDB in production, local Postgres in development)
# Pooled URL for the runtime — use Neon's "-pooler" hostname in prod
DATABASE_URL=postgresql://user:password@host:5432/db?pgbouncer=true&connection_limit=1
# Direct (unpooled) URL for migrations only — required by Prisma
DIRECT_URL=postgresql://user:password@host:5432/db

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-base64
BETTER_AUTH_URL=http://localhost:3000

# Initial admin (used by scripts/seed-admin.ts; not read at runtime)
ADMIN_INITIAL_EMAIL=ahorrhogar@gmail.com
ADMIN_INITIAL_PASSWORD=replace-me-strong

# Vercel Blob (asset storage; replaces Supabase Storage buckets)
BLOB_READ_WRITE_TOKEN=

# Upstash Redis (rate limiting + click aggregations; replaces Postgres RPC counters)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend (transactional email; currently dormant — only logged in dev)
RESEND_API_KEY=

# Public site URL used by sitemap.ts and robots.ts. Defaults to https://homara.es when unset.
NEXT_PUBLIC_SITE_URL=https://homara.es

# Google Analytics 4
# Server-only var read in layout.tsx and passed via prop. Unset locally = no GA loaded.
GA_ID=
# Required to fire server-side Measurement Protocol events (affiliate redirect, AI crawler visits).
GA4_API_SECRET=
