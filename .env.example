# Supabase configuration
# Public values are exposed to the browser via the NEXT_PUBLIC_ prefix.
# Server-only values are read from the unprefixed names in route handlers, server components, and server actions.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Public site URL used by sitemap.ts and robots.ts. Defaults to https://homara.es when unset.
NEXT_PUBLIC_SITE_URL=https://homara.es
