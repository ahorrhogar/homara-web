// Homara — single source of truth for the application database.
// Migrated from Supabase (34 SQL migrations + RLS) to a single Prisma model file.
// All authorization moves to the app layer; RLS is intentionally not used.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────
// Better Auth — table names lowercased to match Better Auth defaults.
// `role` is a Homara-specific additional field (admin gate).
// ─────────────────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  role          String   @default("user")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions     Session[]
  accounts     Account[]
  adminActions AdminAction[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

// ─────────────────────────────────────────────────────────────────
// Catalog
// ─────────────────────────────────────────────────────────────────

model Brand {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  products Product[]

  @@map("brands")
}

model Category {
  id       String  @id @default(uuid()) @db.Uuid
  name     String
  slug     String?
  icon     String?
  imageUrl String? @map("image_url")
  parentId String? @map("parent_id") @db.Uuid

  parent   Category?  @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryParent")
  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  brandId     String   @map("brand_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  description String
  specs       Json     @default("{}")
  attributes  Json     @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  brand    Brand          @relation(fields: [brandId], references: [id], onDelete: Restrict)
  category Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images   ProductImage[]
  offers   Offer[]
  prices   PriceHistory[]
  clicks   Click[]

  @@index([brandId])
  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  url       String
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Merchant {
  id      String  @id @default(uuid()) @db.Uuid
  name    String
  logoUrl String? @map("logo_url")

  offers Offer[]
  clicks Click[]

  @@map("merchants")
}

model Offer {
  id             String    @id @default(uuid()) @db.Uuid
  productId      String    @map("product_id") @db.Uuid
  merchantId     String    @map("merchant_id") @db.Uuid
  price          Decimal   @db.Decimal(12, 2)
  oldPrice       Decimal?  @map("old_price") @db.Decimal(12, 2)
  url            String
  stock          Boolean   @default(true)
  isActive       Boolean   @default(true) @map("is_active")
  sourceType     String    @default("manual") @map("source_type")
  syncStatus     String    @default("ok") @map("sync_status")
  lastCheckedAt  DateTime? @map("last_checked_at")
  nextCheckAt    DateTime? @map("next_check_at")
  lastSyncError  String?   @map("last_sync_error")
  priorityScore  Decimal   @default(0) @map("priority_score") @db.Decimal(10, 2)
  freshnessScore Decimal   @default(100) @map("freshness_score") @db.Decimal(6, 2)
  updatedAt      DateTime  @updatedAt @map("updated_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([merchantId])
  @@index([syncStatus])
  @@index([nextCheckAt])
  @@map("offers")
}

model PriceHistory {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  price     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt(sort: Desc)])
  @@map("price_history")
}

// ─────────────────────────────────────────────────────────────────
// Tracking — anonymous inserts. Rate limits live in Redis.
// ─────────────────────────────────────────────────────────────────

model Click {
  id         String   @id @default(uuid()) @db.Uuid
  productId  String   @map("product_id") @db.Uuid
  merchantId String   @map("merchant_id") @db.Uuid
  offerId    String?  @map("offer_id") @db.Uuid
  ipHash     String?  @map("ip_hash")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("clicks")
}

model SearchEvent {
  id             String   @id @default(uuid()) @db.Uuid
  sessionId      String   @map("session_id")
  term           String
  normalizedTerm String   @map("normalized_term")
  resultCount    Int      @default(0) @map("result_count")
  topProductId   String?  @map("top_product_id") @db.Uuid
  path           String?
  ipHash         String?  @map("ip_hash")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([normalizedTerm, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("search_events")
}

model ArticleViewEvent {
  id          String   @id @default(uuid()) @db.Uuid
  articleId   String   @map("article_id") @db.Uuid
  articleSlug String   @map("article_slug")
  sessionId   String   @map("session_id")
  path        String?
  referrer    String?
  ipHash      String?  @map("ip_hash")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  article EditorialArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, createdAt(sort: Desc)])
  @@map("article_view_events")
}

// ─────────────────────────────────────────────────────────────────
// Editorial
// ─────────────────────────────────────────────────────────────────

model EditorialArticle {
  id                   String    @id @default(uuid()) @db.Uuid
  slug                 String    @unique
  path                 String    @unique
  title                String
  excerpt              String
  coverImage           String?   @map("cover_image")
  coverImageAlt        String?   @map("cover_image_alt")
  coverTone            String    @default("fresh") @map("cover_tone")
  categorySlug         String    @map("category_slug")
  categoryName         String    @map("category_name")
  intent               String
  tags                 String[]
  readMinutes          Int       @default(8) @map("read_minutes")
  averageBudget        Decimal?  @map("average_budget") @db.Decimal(10, 2)
  relatedCategorySlugs String[]  @map("related_category_slugs")
  relatedProductSlugs  String[]  @map("related_product_slugs")
  publishedAt          DateTime? @map("published_at")
  status               String    @default("draft")
  isFeatured           Boolean   @default(false) @map("is_featured")
  viewsCount           Int       @default(0) @map("views_count")
  sections             Json      @default("[]")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  views ArticleViewEvent[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([isFeatured, publishedAt(sort: Desc)])
  @@map("editorial_articles")
}

// ─────────────────────────────────────────────────────────────────
// Admin audit log
// ─────────────────────────────────────────────────────────────────

model AdminAction {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  payload    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("admin_actions")
}
